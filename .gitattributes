# Auto-detect text files and normalize line endings to LF in the repo
* text=auto eol=lf

# Windows batch/script files use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.vbs text eol=crlf
*.ps1 text eol=crlf

# Binary files — no line-ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mp3 binary
*.mp4 binary
*.wav binary
